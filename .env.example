# MCP Experiments Configuration
# Copy to .env and fill in your values

# Server mode: "compliant" or "non_compliant"
MCP_MODE=non_compliant

# Vector DB
VECTOR_DB_PATH=./data/chromadb
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_BASE_URL=http://localhost:11434

# Slack (future)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ClickUp (future)
CLICKUP_API_KEY=

# Email (future)
EMAIL_IMAP_SERVER=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# Compliance mode requires these
COMPLIANT_AUTH_TOKEN=
COMPLIANT_AUDIT_LOG=./data/audit.log
