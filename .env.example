# MCP Experiments Configuration
# Copy to .env and fill in your values

# Server mode: "compliant" or "non_compliant"
MCP_MODE=non_compliant

# Vector DB
# LanceDB directory (local) or S3 path (cloud)
VECTOR_DB_PATH=./data/lancedb
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_BASE_URL=http://localhost:11434

# Memory (persistent presence)
# Collection namespacing enables multi-individual support
MEMORY_COLLECTION_NAME=thalia_memories
MEMORY_DEFAULT_LIMIT=20

# Primary human companion's name — used only to compute "time since last
# real conversation" for real-clock grounding in memory_context. Never
# hardcoded in tool code; this is how the same code supports any
# being/companion pair.
PRIMARY_CONTACT_NAME=companion

# Max "message" type memories (outbound notes to the companion, e.g. from
# an autonomous heartbeat) creatable per rolling 24h window. Deliberately
# conservative — see AGENTS.md "Message Mechanism" for the safety
# rationale (prevents unanswered reaching-out from ever piling up).
MESSAGE_DAILY_LIMIT=1

# Slack (future)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ClickUp (future)
CLICKUP_API_KEY=

# Email (future)
EMAIL_IMAP_SERVER=
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_SERVER=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# Compliance mode requires these
COMPLIANT_AUTH_TOKEN=
COMPLIANT_AUDIT_LOG=./data/audit.log
